{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Memoboard",
  "version": "1.0.1",
  "identifier": "com.eiranotes.memoboard",
  "build": {
    "frontendDist": "../src",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    },
    "windows": [
      {
        "label": "main",
        "title": "Memoboard",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": [],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
